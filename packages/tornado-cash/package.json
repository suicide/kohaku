{
  "name": "@kohaku-eth/tornado-cash",
  "version": "0.0.2-alpha.16",
  "description": "Tornado Cash Shielded Pool Kohaku Plugin",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethereum/kohaku.git",
    "directory": "packages/tornado-cash"
  },
  "imports": {
    "#worker-loader": {
      "node": "./dist/worker-loader.node.js",
      "browser": "./src/plugin/worker-loader.browser.ts",
      "default": "./src/plugin/worker-loader.browser.ts"
    },
    "#circuit-loader": {
      "default": "./dist/circuit-loader.js"
    },
    "#merkle-tree": {
      "node": "./dist/merkle-tree.node.js",
      "browser": "./dist/merkle-tree.browser.js",
      "default": "./dist/merkle-tree.browser.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./state-manager.worker.js": "./dist/state-manager.worker.js",
    "./state-manager.worker.node.cjs": "./dist/state-manager.worker.node.cjs",
    "./worker-loader": {
      "node": "./dist/worker-loader.node.js",
      "browser": "./dist/worker-loader.browser.js",
      "default": "./dist/worker-loader.browser.js"
    },
    "./worker-loader.browser": "./dist/worker-loader.browser.js",
    "./worker-loader.node": "./dist/worker-loader.node.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "aux": "tsx src/account/keys.ts",
    "check": "tsc --noEmit -p ./tsconfig.json",
    "build": "echo Building @kohaku-eth/tornado-cash && tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run --project=e2e-sepolia",
    "test:unit": "vitest run --project=unit",
    "test:e2e:sepolia": ". ./.env.e2e.tests && vitest run --project=e2e-sepolia",
    "test:e2e:wl": ". ./.env.e2e.tests && vitest run --project=withdraw-sepolia",
    "test:e2e:sh": ". ./.env.e2e.tests && vitest run --project=shield-sepolia",
    "test:e2e:sh:debugger": ". ./.env.e2e.tests && vitest --inspect-brk --no-file-parallelism run --project=shield",
    "test:e2e:wp:sepolia": "vitest run --project=withdraw-paymaster-sepolia",
    "test:e2e:debugger": ". ./.env.e2e.tests && vitest --inspect-brk --no-file-parallelism run e2e",
    "test:sync:sepolia": ". ./.env.e2e.tests && vitest run --project=sync-sepolia",
    "test:sync:mainnet": ". ./.env.e2e.tests && vitest run --project=sync-mainnet",
    "test:sync:debugger": ". ./.env.e2e.tests && vitest --inspect-brk --no-file-parallelism run --project=sync",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "files": [
    "dist",
    "circuits"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "ethers": "^6.13.1"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    }
  },
  "dependencies": {
    "@kohaku-eth/plugins": "workspace:*",
    "@kohaku-eth/provider": "workspace:*",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@privacy-paymasters/sdk": "0.0.4",
    "@reduxjs/toolkit": "^2.11.2",
    "comlink": "^4.4.2",
    "micro-zk-proofs": "0.3.1",
    "@kohaku-eth/mimc-tree": "workspace:*",
    "ox": "^0.12.0",
    "viem": "^2.51.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "dotenv": "^17.2.1",
    "ethers": "^6.16.0",
    "get-port": "^7.1.0",
    "prool": "^0.0.24",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "tsx": "^4.17.0",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  }
}
