    "./dist/MimcMerkleTreeWorker.js",
    "./dist/MimcMerkleTreeBrowserWorker.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fixed-merkle-tree": "0.7.3",
    "micro-wrkr": "^0.2.0",
    "micro-zk-proofs": "^0.3.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
