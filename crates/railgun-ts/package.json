{
  "name": "@kohaku-eth/railgun",
  "version": "0.0.1-alpha.28",
  "description": "Railgun Shielded Pool Kohaku Plugin",
  "type": "module",
  "main": "./dist/sdk/lib.js",
  "types": "./dist/sdk/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/lib.d.ts",
      "import": "./dist/sdk/lib.js",
      "default": "./dist/sdk/lib.js"
    }
  },
  "files": [
    "dist",
    "sdk",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ethereum/kohaku.git",
    "directory": "crates/railgun-ts"
  },
  "private": false,
  "scripts": {
    "build": "pnpm run build:wasm && pnpm run build:js",
    "build:wasm": "wasm-pack build --target web --out-name index --out-dir pkg",
    "build:js": "tsc && cp -r pkg dist/ && rm -f dist/pkg/.gitignore",
    "test:e2e": "pnpm run test:e2e:transact-utxo && pnpm run test:e2e:broadcast-utxo && pnpm run test:e2e:plugin-sync && pnpm run test:e2e:plugin-transact-broadcast",
    "test:e2e:transact-utxo": "INTEGRATION=1 vitest run -t transact-utxo",
    "test:e2e:broadcast-utxo": "INTEGRATION=1 vitest run -t broadcast-utxo",
    "test:e2e:plugin-sync": "INTEGRATION=1 vitest run -t plugin-sync",
    "test:e2e:plugin-transact-broadcast": "INTEGRATION=1 vitest run -t plugin-transact-broadcast"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@kohaku-eth/plugins": "workspace:*",
    "@kohaku-eth/provider": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prool": "^0.2.4",
    "typescript": "^5.9.2",
    "viem": "^2.51.3",
    "vite": "^8.0.2",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.1"
  }
}